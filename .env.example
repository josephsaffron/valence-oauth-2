# Shared Brightspace settings
BRIGHTSPACE_BASE_URL=https://your-org.brightspace.com
BRIGHTSPACE_API_PATH=/d2l/api/lp/1.0/users/whoami

# Legacy Valence ID/Key auth values
# These names map to common Valence terminology.
VALENCE_APP_ID=replace-with-app-id
VALENCE_APP_KEY=replace-with-app-key
VALENCE_USER_ID=replace-with-user-id
VALENCE_USER_KEY=replace-with-user-key

# Optional: freeze timestamp/nonce for deterministic workshop output
LEGACY_FIXED_TIMESTAMP=
LEGACY_FIXED_NONCE=

# OAuth2 demo values
# Option 1: paste a pre-generated access token for fastest workshop flow.
OAUTH2_ACCESS_TOKEN=

# Option 2: request token live via client credentials (if tenant is configured).
OAUTH2_TOKEN_URL=
OAUTH2_CLIENT_ID=
OAUTH2_CLIENT_SECRET=
OAUTH2_SCOPE=

# Demo behavior
DEMO_TIMEOUT_MS=15000
